# Required env vars for the OpenCode web deploy on Railway.
# Copy to .env for local use, OR set these as Variables in the Railway dashboard
# (Settings -> Variables) / via `railway variables --set KEY=VALUE`.
# Do NOT commit real values — .env is gitignored.

# Required: protects the public OpenCode web UI (HTTP basic auth).
OPENCODE_SERVER_PASSWORD=

# Required to run a model: your OpenCode Go / Zen API key (from the OpenCode Zen console).
# Picked up automatically by opencode — no `opencode auth login` needed.
OPENCODE_API_KEY=

# Web UI login username (defaults to "opencode" if unset).
OPENCODE_SERVER_USERNAME=opencode

# Do NOT set PORT — Railway injects it automatically and entrypoint.sh reads it.
