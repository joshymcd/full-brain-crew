# Required env vars for the OpenCode web deploy on Railway.
# Copy to .env for local use, OR set these as Variables in the Railway dashboard
# (Settings -> Variables) / via `railway variables --set KEY=VALUE`.
# Do NOT commit real values — .env is gitignored.

# Required: protects the public OpenCode web UI (HTTP basic auth).
OPENCODE_SERVER_PASSWORD=

# Required to run a model: your OpenCode Go / Zen API key (from the OpenCode Zen console).
# Picked up automatically by opencode — no `opencode auth login` needed.
OPENCODE_API_KEY=

# Web UI login username (defaults to "opencode" if unset).
OPENCODE_SERVER_USERNAME=opencode

# Full Brain Crew dependency source. Defaults to upstream main, so every boot
# reinstalls/updates crew-owned files into /vault. Pin CREW_REF to a commit or
# tag for reproducible boots, or override CREW_REPO for forks/dev builds.
# CREW_REPO=https://github.com/gnekt/My-Brain-Is-Full-Crew.git
# CREW_REF=main

# -- Workspace sync (optional) ------------------------------------------------
# Valid values today: none, local, obsidian, git. If unset, OBSIDIAN_VAULT_NAME
# still turns on the Obsidian backend for backwards compatibility. Use
# SYNC_BACKEND=none to force ephemeral local-only mode even when provider-specific
# vars are present. Use SYNC_BACKEND=local when persistence is provided by a
# Docker bind mount, Railway volume, or host filesystem.
SYNC_BACKEND=
# Default is false: sync failures warn but OpenCode still starts. Set true if the
# assistant should not boot unless the selected sync backend is working.
SYNC_REQUIRED=false
# Local workspace path for OpenCode + Full Brain Crew. Keep /vault unless you are
# intentionally changing the container layout.
WORKSPACE_PATH=/vault

# -- Obsidian Sync backend (optional) -----------------------------------------
# The vault must already exist in Obsidian Sync.
OBSIDIAN_VAULT_NAME=
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=
# Only needed if the vault uses end-to-end encryption (separate from account pw).
OBSIDIAN_ENCRYPTION_PASSWORD=
# Extra folders excluded from sync (comma-separated). .opencode and .git are
# always included so agent config and local OpenCode project metadata stay local.
# OBSIDIAN_EXCLUDED_FOLDERS=.opencode,.git

# -- Git sync backend (optional) ---------------------------------------------
# Use with SYNC_BACKEND=git. GIT_REMOTE_URL should not include credentials.
# Store GIT_TOKEN as a Railway secret. GitHub tokens usually work with the
# default username x-access-token.
GIT_REMOTE_URL=
GIT_BRANCH=main
GIT_TOKEN=
GIT_USERNAME=x-access-token
GIT_AUTHOR_NAME=Full Brain Crew
GIT_AUTHOR_EMAIL=full-brain-crew@example.invalid
GIT_SYNC_INTERVAL_SECONDS=60
GIT_COMMIT_MESSAGE=Update workspace from Full Brain Crew

# -- Google Workspace / gws (optional) ----------------------------------------
# Full contents of a locally-exported `gws auth export --unmasked > credentials.json`.
# Paste the entire JSON. The entrypoint writes it to ~/.config/gws/credentials.json on
# boot. Leave unset to skip Google integration. Store as a SECRET in Railway.
GWS_CREDENTIALS_JSON=

# Do NOT set PORT — Railway injects it automatically and entrypoint.sh reads it.
